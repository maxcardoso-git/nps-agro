# Backend
NODE_ENV=production
PORT=3310
DATABASE_URL=postgresql://user:password@postgres:5432/nps_agro
JWT_SECRET=change-me-to-a-real-secret
JWT_EXPIRES_IN=24h
APP_NAME=nps-agro-api
LOG_LEVEL=info
CORS_ORIGIN=http://72.61.52.70
DB_POOL_MAX=20

# Frontend build args
NEXT_PUBLIC_API_URL=http://72.61.52.70:3310
NEXT_PUBLIC_API_BASE_URL=http://72.61.52.70:3310
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# Docker network (name of the external network where PostgreSQL runs)
DB_NETWORK=nps-db-net
